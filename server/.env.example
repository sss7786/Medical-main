# 复制本文件为 .env 后填写（不要把 .env 打进 zip 提交）

OPENAI_API_KEY=sk-xxxxxxxx

# 与所用平台文档一致（以下为常见写法）：
#
# OpenAI 官方（需 /v1）：
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# DeepSeek（无 /v1；与 OpenAI SDK 示例一致 base_url=https://api.deepseek.com ）：
# 文档：https://api-docs.deepseek.com/zh-cn/
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名示例：gpt-4o-mini | deepseek-v4-flash | deepseek-v4-pro（以平台文档为准）
OPENAI_MODEL=gpt-4o-mini
